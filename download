import { IncomingMessage, ServerResponse } from "http";
import { tenlyr } from "../client";
import { AuthenticationError, NotFoundError } from "@tenlyr/sdk";

export interface TenantRequest extends IncomingMessage {
  tenantId?: string;
  tenantApiKey?: string;
}

type Handler = (req: TenantRequest, res: ServerResponse) => void | Promise<void>;

/**
 * enforceTenancy middleware
 *
 * Reads X-Tenant-API-Key header from the request.
 * Validates the key against Tenlyr — real cryptographic check, not a lookup table.
 * Attaches tenantId + key to the request for downstream use.
 *
 * Any route wrapped with this is guaranteed to be tenant-scoped.
 * Any route NOT wrapped with this cannot touch tenant data.
 */
export function enforceTenancy(handler: Handler): Handler {
  return async (req, res) => {
    const tenantKey = extractTenantKey(req);

    if (!tenantKey) {
      return sendError(res, 400, {
        error: "Missing tenant key",
        hint: "Set the X-Tenant-API-Key header with your tenant's API key.",
      });
    }

    try {
      // Validate by hitting Tenlyr's usage metrics endpoint —
      // only a live, active tenant key returns 200
      const metrics = await tenlyr.usage.metrics(tenantKey);

      // Attach to request so handlers can read without re-fetching
      (req as TenantRequest).tenantId = metrics.tenantId;
      (req as TenantRequest).tenantApiKey = tenantKey;

      await handler(req as TenantRequest, res);
    } catch (err) {
      if (err instanceof AuthenticationError) {
        return sendError(res, 401, {
          error: "Invalid or revoked tenant key",
          hint: "Rotate your key via the Tenlyr dashboard if needed.",
        });
      }
      if (err instanceof NotFoundError) {
        return sendError(res, 401, {
          error: "Tenant not found or suspended",
        });
      }
      throw err;
    }
  };
}

/**
 * trackUsage — fire-and-forget usage event after every successful request.
 * Call this at the end of each handler.
 */
export async function trackUsage(
  tenantKey: string,
  endpoint: string
): Promise<void> {
  tenlyr.usage
    .track({ tenantKey, metric: "api_call", value: 1, endpoint })
    .catch((err) => console.warn("[tenlyr] usage track failed:", err.message));
}

// ── Helpers ────────────────────────────────────────────────────────────────

function extractTenantKey(req: IncomingMessage): string | null {
  const header = req.headers["x-tenant-api-key"];
  if (header && typeof header === "string") return header.trim();
  return null;
}

function sendError(res: ServerResponse, code: number, body: object) {
  res.writeHead(code, { "Content-Type": "application/json" });
  res.end(JSON.stringify(body));
}
